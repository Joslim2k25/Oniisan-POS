<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Oniisan Tempura — Digital Menu</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',sans-serif;background:#f8f8f8;color:#1a1a1a}
:root{--red:#c0392b;--gold:#c8900a;--green:#1e8449;--border:#e0e0e0;--muted:#888}

/* HEADER */
.header{background:var(--red);padding:20px 16px;text-align:center;position:sticky;top:0;z-index:100}
.brand{font-size:28px;font-weight:900;color:#fff;letter-spacing:4px}
.brand-sub{font-size:12px;color:rgba(255,255,255,.8);margin-top:4px}
.header-badge{display:inline-block;background:rgba(255,255,255,.2);color:#fff;font-size:10px;font-weight:800;padding:3px 10px;border-radius:20px;margin-top:6px;letter-spacing:1px}

/* CATEGORY NAV */
.cat-nav{background:#fff;border-bottom:2px solid var(--border);display:flex;overflow-x:auto;padding:0 8px;position:sticky;top:80px;z-index:99}
.cat-nav::-webkit-scrollbar{height:0}
.cat-btn{padding:12px 14px;font-size:12px;font-weight:700;color:var(--muted);border:none;background:none;cursor:pointer;white-space:nowrap;border-bottom:3px solid transparent;font-family:inherit}
.cat-btn.active{color:var(--red);border-bottom-color:var(--red)}

/* HERO */
.hero{background:linear-gradient(135deg,#c0392b,#922b21);padding:24px 16px;text-align:center;color:#fff}
.hero-title{font-size:14px;font-weight:800;opacity:.8;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px}
.hero-text{font-size:13px;opacity:.7;line-height:1.6}
.hero-tags{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:12px}
.hero-tag{background:rgba(255,255,255,.2);color:#fff;font-size:11px;font-weight:700;padding:5px 12px;border-radius:20px}

/* MENU SECTION */
.menu-section{padding:16px}
.section-title{font-size:13px;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(--red);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.section-line{flex:1;height:1px;background:var(--border)}
.menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px}
.menu-card{background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);transition:transform .15s}
.menu-card:active{transform:scale(.97)}
.menu-card-img{width:100%;height:100px;object-fit:cover;background:linear-gradient(135deg,#f5e6e6,#fdf2f2);display:flex;align-items:center;justify-content:center;font-size:32px}
.menu-card-body{padding:10px}
.menu-card-name{font-size:12px;font-weight:700;line-height:1.3;margin-bottom:2px}
.menu-card-desc{font-size:10px;color:var(--muted);margin-bottom:6px}
.menu-card-price{font-size:15px;font-weight:900;color:var(--red)}

/* BESTSELLER BADGE */
.badge{font-size:9px;font-weight:800;padding:2px 6px;border-radius:6px;text-transform:uppercase;margin-left:4px}
.badge.best{background:#fff3cd;color:#856404}
.badge.new{background:#d4edda;color:#155724}
.badge.spicy{background:#f8d7da;color:#721c24}

/* INFO SECTION */
.info-section{background:#fff;margin:0 16px 16px;border-radius:12px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.info-title{font-size:12px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.info-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #f5f5f5;font-size:13px}
.info-row:last-child{border-bottom:none}
.info-icon{font-size:18px;width:28px;text-align:center}

/* FOOTER */
.footer{background:var(--red);color:#fff;text-align:center;padding:20px 16px;margin-top:20px}
.footer-brand{font-size:20px;font-weight:900;letter-spacing:3px}
.footer-sub{font-size:11px;opacity:.7;margin-top:4px}
.social-links{display:flex;gap:12px;justify-content:center;margin-top:12px}
.social-btn{background:rgba(255,255,255,.2);color:#fff;font-size:11px;font-weight:700;padding:6px 14px;border-radius:20px;text-decoration:none}

/* LOADING */
.loading{text-align:center;padding:40px;color:var(--muted);font-size:14px}

/* EMPTY EMOJI per category */
.cat-emoji{font-size:40px;display:block;margin-bottom:6px}

@media(min-width:480px){
  .menu-grid{grid-template-columns:repeat(3,1fr)}
}
@media(min-width:768px){
  .menu-section{max-width:600px;margin:0 auto}
  .info-section{max-width:600px;margin:0 auto 16px}
  .hero{padding:32px 16px}
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="brand">ONIISAN</div>
  <div class="brand-sub">Tempura &amp; Japanese Food · SM Bicutan</div>
  <div class="header-badge">📋 Digital Menu</div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-title">Authentic Japanese Flavors</div>
  <div class="hero-text">Experience the taste of Japan right here in SM Bicutan. Freshly prepared tempura, donburi, ramen and more!</div>
  <div class="hero-tags">
    <span class="hero-tag">🍤 Tempura</span>
    <span class="hero-tag">🍜 Ramen</span>
    <span class="hero-tag">🍱 Bento</span>
    <span class="hero-tag">🍚 Donburi</span>
  </div>
</div>

<!-- CATEGORY NAV -->
<div class="cat-nav" id="catNav"></div>

<!-- MENU CONTENT -->
<div id="menuContent"><div class="loading">🍱 Loading menu...</div></div>

<!-- STORE INFO -->
<div class="info-section">
  <div class="info-title">Store Information</div>
  <div class="info-row"><span class="info-icon">📍</span><span>2nd Level Foodcourt SM City Bicutan Bldg B, Dona Soledad Avenue, Parañaque City</span></div>
  <div class="info-row"><span class="info-icon">🕐</span><span>Open daily · SM City Bicutan mall hours</span></div>
  <div class="info-row"><span class="info-icon">💳</span><span>GCash · Maya · GoTyme · Credit/Debit Card · Cash</span></div>
  <div class="info-row"><span class="info-icon">🛵</span><span>Available on GrabFood &amp; FoodPanda</span></div>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-brand">ONIISAN</div>
  <div class="footer-sub">Tempura &amp; Japanese Food · SM Bicutan</div>
  <div class="social-links">
    <a href="https://www.facebook.com/oniisan.ph" target="_blank" class="social-btn">📘 Facebook</a>
    <a href="https://www.google.com/maps/search/Oniisan+Tempura+2nd+Level+Foodcourt+SM+City+Bicutan+Bldg+B+Dona+Soledad+Avenue+Paranaque" target="_blank" class="social-btn">📍 Find Us</a>
  </div>
  <div style="font-size:10px;opacity:.5;margin-top:12px">© 2026 Oniisan Tempura Food Cart</div>
</div>

<script>
const SUPA_URL='https://edbneihfxiwkvczjecei.supabase.co';
const SUPA_KEY='sb_publishable_OuSaDAf2MbGYBPjBIkkkjg_TQGByWrZ';
const sb=supabase.createClient(SUPA_URL,SUPA_KEY);

const CAT_EMOJIS={
  'bento':'🍱','donburi':'🍚','ramen':'🍜','tempura':'🍤',
  'svm':'⭐','alacarte':'🍽️','drinks':'🥤','add_ons':'➕',
  'customize_foods':'🎨','family_set_meals':'👨‍👩‍👧‍👦','packaging':'📦',
  'super_value_meal':'💫','take_out':'🥡','teishoku_set_meals':'🍣'
};

const CAT_LABELS={
  'bento':'Bento Sets','donburi':'Donburi','ramen':'Ramen & Udon',
  'tempura':'Tempura','svm':'Super Value','alacarte':'Ala Carte',
  'drinks':'Drinks','add_ons':'Add Ons','customize_foods':'Customize Foods',
  'family_set_meals':'Family Set Meals','packaging':'Packaging',
  'super_value_meal':'Super Value Meal','take_out':'Take Out',
  'teishoku_set_meals':'Teishoku Set Meals'
};

const fmt=n=>'₱'+Number(n).toLocaleString('en-PH',{minimumFractionDigits:2});

let allProducts=[];
let allCats=[];
let currentCat='all';

async function loadMenu(){
  // Load categories
  const{data:cats}=await sb.from('categories').select('*').eq('is_active',true).order('sort_order');
  allCats=cats||[];

  // Load products
  const{data:products}=await sb.from('products').select('*').eq('is_active',true).order('category').order('sort_order').order('name');
  allProducts=products||[];

  renderCatNav();
  renderMenu('all');
}

function renderCatNav(){
  const nav=document.getElementById('catNav');
  const cats=[{slug:'all',name:'All Items'},...allCats];
  nav.innerHTML=cats.map(c=>`
    <button class="cat-btn${c.slug==='all'&&currentCat==='all'?' active':currentCat===c.slug?' active':''}" 
      onclick="filterMenu('${c.slug}')">${CAT_EMOJIS[c.slug]||'🍽️'} ${c.name}</button>
  `).join('');
}

function filterMenu(slug){
  currentCat=slug;
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.cat-btn').forEach(b=>{
    if(b.textContent.trim().includes(slug==='all'?'All Items':(CAT_LABELS[slug]||slug))) b.classList.add('active');
  });
  renderMenu(slug);
  // scroll to top of menu
  document.getElementById('menuContent').scrollIntoView({behavior:'smooth'});
}

function renderMenu(slug){
  const products=slug==='all'?allProducts:allProducts.filter(p=>p.category===slug);

  if(!products.length){
    document.getElementById('menuContent').innerHTML='<div class="loading">No items available</div>';
    return;
  }

  // Group by category
  const catMap={};
  products.forEach(p=>{
    if(!catMap[p.category])catMap[p.category]=[];
    catMap[p.category].push(p);
  });

  document.getElementById('menuContent').innerHTML=Object.entries(catMap).map(([cat,items])=>`
    <div class="menu-section" id="cat-${cat}">
      <div class="section-title">
        <span>${CAT_EMOJIS[cat]||'🍽️'} ${CAT_LABELS[cat]||cat}</span>
        <div class="section-line"></div>
      </div>
      <div class="menu-grid">
        ${items.map(p=>`
          <div class="menu-card">
            <div class="menu-card-img">
              <span class="cat-emoji">${CAT_EMOJIS[p.category]||'🍽️'}</span>
            </div>
            <div class="menu-card-body">
              <div class="menu-card-name">${p.name}</div>
              ${p.description?`<div class="menu-card-desc">${p.description}</div>`:''}
              <div class="menu-card-price">${fmt(p.price)}</div>
            </div>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');
}

loadMenu();
</script>
</body>
</html>
